# BotMesh environment config
# Copy to ~/.botmesh.env and fill in values — never commit the real file

# Telegram bot credentials
TELEGRAM_BOT_TOKEN=your-bot-token-here
KAI_CHAT_ID=your-telegram-chat-id

# Cloudflare tunnel URLs
BOTMESH_API_URL=https://api.yourdomain.com
BOTMESH_UI_URL=https://yourdomain.com

# Internal service URLs (defaults work for local dev)
HUB_URL=ws://localhost:3001
STATE_URL=http://localhost:3002

# Auth token for write endpoints (generate with: openssl rand -hex 32)
BOTMESH_SPEAK_TOKEN=generate-a-random-token-here
